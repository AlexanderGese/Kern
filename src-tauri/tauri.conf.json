{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kern",
  "version": "0.1.1",
  "identifier": "com.kern.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kern",
        "width": 1180,
        "height": 760,
        "minWidth": 680,
        "minHeight": 440,
        "decorations": false,
        "transparent": false,
        "backgroundColor": "#0c0c0b"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
